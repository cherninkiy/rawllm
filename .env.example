# Copy this file to .env and fill in your credentials.
# cp .env.example .env

# ── LLM provider ──────────────────────────────────────────────────────────────
# Which provider to use (default: anthropic).
# Supported: anthropic | groq | gemini | openrouter | deepseek | ollama | ollama-qwen-coder
LLM_PROVIDER=anthropic

# Override the default model for any provider (optional).
# LLM_MODEL=claude-3-5-sonnet-20241022

# Override the base URL for OpenAI-compatible providers (optional).
# LLM_BASE_URL=https://api.example.com/v1

# ── API keys (only the one matching LLM_PROVIDER is required) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# OPEN_ROUTER_API_KEY=sk-or-...
# DEEPSEEK_API_KEY=sk-...
# Ollama needs no key – just ensure the server is reachable.

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Backend for plugin execution: subprocess (default) or docker
# SANDBOX_BACKEND=subprocess

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
